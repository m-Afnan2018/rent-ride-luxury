PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/rent-ride-luxury

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000
PRODUCTION_CLIENT_URL=https://yourdomain.com

# File uploads
UPLOADS_DIR=uploads
MAX_FILE_SIZE=10485760

# Admin seed
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@rentluxury.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_PHONE=+1234567890
